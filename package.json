{
  "name": "orca-ui",
  "packageManager": "yarn@4.6.0",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "bash -c 'source start.sh'",
    "dev": "bash -c 'source start.sh'",
    "tsc-check": "tsc --build --force",
    "build": "curl -o ./public/assets/metadata-schema.svg https://raw.githubusercontent.com/umccr/orcabus/refs/heads/main/lib/workload/stateless/stacks/metadata-manager/docs/schema.drawio.svg && vite build",
    "lint": "eslint --ignore-pattern 'deploy/cdk.out'",
    "prettier-fix": "prettier . --write --ignore-path .gitignore --ignore-path deploy/.gitignore",
    "prettier-check": "prettier . --check --ignore-path .gitignore --ignore-path deploy/.gitignore",
    "preview": "vite preview",
    "precommit": "pre-commit run --all-files",
    "audit": "yarn npm audit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "mart-codegen-graphql": "yarn graphql-codegen --config ./src/modules/orcavault/api/graphql/codegen.ts"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@tanstack/react-query": "^5.95.2",
    "@xyflow/react": "^12.10.1",
    "aws-amplify": "^6.16.3",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "dayjs": "^1.11.20",
    "graphql": "^16.13.2",
    "igv": "^3.8.0",
    "mime-db": "^1.54.0",
    "openapi-fetch": "^0.17.0",
    "openapi-react-query": "^0.5.4",
    "pako": "^2.1.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-flatpickr": "^4.0.11",
    "react-loading-skeleton": "^3.5.0",
    "react-router-dom": "^7.13.2",
    "react-toastify": "^11.0.5",
    "tailwind-merge": "^3.5.0",
    "unsplash-js": "^7.0.20"
  },
  "devDependencies": {
    "@0no-co/graphqlsp": "^1.15.2",
    "@chromatic-com/storybook": "^5.1.0",
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/schema-ast": "^5.0.1",
    "@parcel/watcher": "^2.5.6",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-links": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.2.2",
    "@types/d3": "^7.4.3",
    "@types/mime-db": "^1.43.6",
    "@types/node": "^25.5.0",
    "@types/pako": "^2.0.4",
    "@types/papaparse": "^5.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-flatpickr": "^3.8.11",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.3",
    "globals": "^17.4.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "^10.3.3",
    "storybook-addon-remix-react-router": "^6.1.0",
    "storybook-react-context": "^0.10.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.3.1",
    "vite-plugin-checker": "^0.12.0"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
